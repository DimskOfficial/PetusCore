# PetusCore configuration — copy to .env and adjust for your deployment.

# Port the server listens on (Dokploy injects this automatically).
PORT=8080

# Where the JSON database is stored. In Docker/Dokploy mount a volume here.
PETUS_DB_PATH=/data

# Public server name shown on the site / API.
PETUS_SERVER_NAME=PetusGDPS

# Secret used to sign API session tokens — CHANGE THIS.
PETUS_API_SECRET=change-me-please

# Username that is auto-promoted to admin on its first REST login.
PETUS_ADMIN_USER=Dimsk

# true = accounts are active immediately; false = require activation.
PETUS_PREACTIVATE=true

# Direct download URL for the modified GD client (used by the site's Download button).
PETUS_GAME_DOWNLOAD_URL=
